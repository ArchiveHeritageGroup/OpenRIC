#!/bin/bash
# OpenRiC Full Audit Suite
# Runs all audit scripts in order and generates reports.
#
# Usage:
#   ./bin/audit-all [OPTIONS]
#
# Options:
#   --fix         Also run auto-fix scripts after auditing
#   --quick       Skip HTTP parity check (slow)
#   --output DIR  Output directory for reports (default: docs/)
#   --help        Show this help

set -uo pipefail

OPENRIC_ROOT="/usr/share/nginx/OpenRiC"
BIN_DIR="${OPENRIC_ROOT}/bin"
OUTPUT_DIR="${OPENRIC_ROOT}/docs"
RUN_FIX=0
SKIP_HTTP=0

# ── Parse arguments ──
while [[ $# -gt 0 ]]; do
    case "$1" in
        --fix)
            RUN_FIX=1
            shift
            ;;
        --quick)
            SKIP_HTTP=1
            shift
            ;;
        --output)
            OUTPUT_DIR="$2"
            shift 2
            ;;
        --help)
            head -14 "$0" | tail -12
            exit 0
            ;;
        *)
            echo "Unknown option: $1"
            echo "Run with --help for usage."
            exit 1
            ;;
    esac
done

# Ensure output directory exists
mkdir -p "${OUTPUT_DIR}"

# ── Banner ──
echo "============================================"
echo "  OpenRiC Full Audit Suite"
echo "  Root:    ${OPENRIC_ROOT}"
echo "  Output:  ${OUTPUT_DIR}"
echo "  Fix:     $([ $RUN_FIX -eq 1 ] && echo 'yes' || echo 'no')"
echo "  Quick:   $([ $SKIP_HTTP -eq 1 ] && echo 'yes (skip HTTP parity)' || echo 'no')"
echo "  Started: $(date '+%Y-%m-%d %H:%M:%S')"
echo "============================================"
echo ""

PASS=0
FAIL=0
SKIP=0

# ── Helper: run a script step ──
run_step() {
    local step_num="$1"
    local description="$2"
    local script_path="$3"
    local output_file="${4:-}"
    local extra_args="${5:-}"

    echo "──────────────────────────────────────────"
    echo "  Step ${step_num}: ${description}"
    echo "──────────────────────────────────────────"

    if [ ! -f "${script_path}" ]; then
        echo "  SKIP  Script not found: ${script_path}"
        SKIP=$((SKIP + 1))
        echo ""
        return
    fi

    # Determine interpreter
    local interpreter=""
    if [[ "${script_path}" == *.php ]]; then
        interpreter="php"
    elif [[ -x "${script_path}" ]]; then
        interpreter=""
    else
        interpreter="bash"
    fi

    local start_time
    start_time=$(date +%s)

    if [ -n "${output_file}" ]; then
        # Audit scripts exit 1 when issues found (expected). Only FAIL on signal/crash (exit >= 128).
        ${interpreter} "${script_path}" ${extra_args} > "${output_file}" 2>&1
        local exit_code=$?
        local end_time
        end_time=$(date +%s)
        local duration=$((end_time - start_time))
        local line_count
        line_count=$(wc -l < "${output_file}")
        if [ ${exit_code} -ge 128 ] || [ ${line_count} -eq 0 ]; then
            echo "  FAIL  Script crashed (exit ${exit_code}, ${duration}s)"
            echo "        Output saved to: ${output_file}"
            FAIL=$((FAIL + 1))
        else
            echo "  PASS  Output: ${output_file} (${line_count} lines, ${duration}s)"
            PASS=$((PASS + 1))
        fi
    else
        if ${interpreter} "${script_path}" ${extra_args} 2>&1; then
            PASS=$((PASS + 1))
        else
            echo "  FAIL  Script exited with error"
            FAIL=$((FAIL + 1))
        fi
    fi

    echo ""
}

# ── Audit Steps ──

# Step 1: Route parity
run_step "1" "Route Parity Check" \
    "${BIN_DIR}/parity-routes.php" \
    "${OUTPUT_DIR}/ROUTE-PARITY-REPORT.txt"

# Step 2: Control parity
run_step "2" "Control Parity Audit" \
    "${BIN_DIR}/audit-controls.php" \
    "${OUTPUT_DIR}/FULL-CONTROL-AUDIT.txt"

# Step 3: Field parity
run_step "3" "Field Parity Check" \
    "${BIN_DIR}/parity-check.php" \
    "${OUTPUT_DIR}/FIELD-PARITY-REPORT.txt"

# Step 4: URL audit (all)
run_step "4" "URL Audit (all)" \
    "${BIN_DIR}/audit-all-urls.php" \
    "${OUTPUT_DIR}/URL-AUDIT-ALL.txt"

# Step 5: URL scoped audit
run_step "5" "URL Scoped Audit" \
    "${BIN_DIR}/audit-urls.php" \
    "${OUTPUT_DIR}/URL-SCOPED-AUDIT.txt"

# Step 6: URL comparison v2
run_step "6" "URL Comparison (v2)" \
    "${BIN_DIR}/audit-urls-v2.php" \
    "${OUTPUT_DIR}/URL-AUDIT-V2.txt"

# Step 7: Missing views
run_step "7" "Missing Views Report" \
    "${BIN_DIR}/missing-views.php" \
    "${OUTPUT_DIR}/MISSING-VIEWS-REPORT.txt"

# Step 8: HTTP parity (unless --quick)
if [ $SKIP_HTTP -eq 0 ]; then
    run_step "8" "HTTP Parity Check (slow)" \
        "${BIN_DIR}/parity-check" \
        "/tmp/openric-parity-report.html"
else
    echo "──────────────────────────────────────────"
    echo "  Step 8: HTTP Parity Check"
    echo "──────────────────────────────────────────"
    echo "  SKIP  --quick flag set"
    SKIP=$((SKIP + 1))
    echo ""
fi

# ── Fix Steps (only with --fix) ──

if [ $RUN_FIX -eq 1 ]; then
    echo ""
    echo "============================================"
    echo "  Running Auto-Fix Scripts"
    echo "============================================"
    echo ""

    # Step 9: Badge & button fixer (pass 1)
    run_step "9" "Fix Badges & Buttons (Pass 1)" \
        "${BIN_DIR}/fix-badges-and-buttons.php" \
        ""

    # Step 10: Badge fixer (pass 2)
    run_step "10" "Fix Badges (Pass 2)" \
        "${BIN_DIR}/fix-badges-pass2.php" \
        ""

    # Step 11: Badge fixer (pass 3)
    run_step "11" "Fix Badges (Pass 3 - DOTALL)" \
        "${BIN_DIR}/fix-badges-pass3.php" \
        ""

    # Step 12: Broken route fixer
    run_step "12" "Fix Broken Routes" \
        "${BIN_DIR}/fix-broken-routes.php" \
        ""
fi

# ── Summary ──
echo ""
echo "============================================"
echo "  Audit Complete"
echo "============================================"
echo "  Passed:  ${PASS}"
echo "  Failed:  ${FAIL}"
echo "  Skipped: ${SKIP}"
echo ""

# Print key metrics from generated reports
echo "  ── Report Highlights ──"

if [ -f "${OUTPUT_DIR}/FULL-CONTROL-AUDIT.txt" ]; then
    local_lines=$(wc -l < "${OUTPUT_DIR}/FULL-CONTROL-AUDIT.txt")
    echo "  Control Audit:     ${local_lines} lines"
fi

if [ -f "${OUTPUT_DIR}/FIELD-PARITY-REPORT.txt" ]; then
    local_lines=$(wc -l < "${OUTPUT_DIR}/FIELD-PARITY-REPORT.txt")
    echo "  Field Parity:      ${local_lines} lines"
fi

if [ -f "${OUTPUT_DIR}/URL-AUDIT-ALL.txt" ]; then
    local_lines=$(wc -l < "${OUTPUT_DIR}/URL-AUDIT-ALL.txt")
    echo "  URL Audit (all):   ${local_lines} lines"
fi

if [ -f "${OUTPUT_DIR}/MISSING-VIEWS-REPORT.txt" ]; then
    local_lines=$(wc -l < "${OUTPUT_DIR}/MISSING-VIEWS-REPORT.txt")
    echo "  Missing Views:     ${local_lines} lines"
fi

if [ -f "/tmp/openric-parity-report.html" ]; then
    local_lines=$(wc -l < "/tmp/openric-parity-report.html")
    echo "  HTTP Parity:       ${local_lines} lines (HTML)"
fi

echo ""
echo "  Finished: $(date '+%Y-%m-%d %H:%M:%S')"
echo "============================================"
