#!/bin/bash
#===============================================================================
# OpenRiC - Release Script
#===============================================================================
# Usage: ./bin/release patch|minor|major "commit message" [--issue N]
#
# Examples:
#   ./bin/release patch "Fix SPARQL query timeout"
#   ./bin/release minor "Add entity browser" --issue 5
#   ./bin/release patch "Bug fixes" --issue 3,4,7
#===============================================================================
set -e

TYPE=${1:-patch}
MSG=${2:-"Bug fixes and improvements"}
ISSUE_ARG=""

for arg in "$@"; do
    if [[ "$arg" == "--issue" ]]; then
        ISSUE_ARG="next"
    elif [[ "$ISSUE_ARG" == "next" ]]; then
        ISSUE_ARG="$arg"
    fi
done

cd "$(dirname "$0")/.."
REPO="ArchiveHeritageGroup/OpenRiC"

VERSION_FILE="version.json"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'

echo -e "${CYAN}════════════════════════════════════════════${NC}"
echo -e "${CYAN}  OpenRiC - Release${NC}"
echo -e "${CYAN}════════════════════════════════════════════${NC}"
echo ""

if [ ! -f "$VERSION_FILE" ]; then
    echo -e "${RED}Error: version.json not found${NC}"; exit 1
fi

CURRENT=$(php -r "\$j=json_decode(file_get_contents('${VERSION_FILE}'),true); echo \$j['version'] ?? '0.1.0';")
if [ -z "$CURRENT" ] || [ "$CURRENT" = "null" ]; then
    echo -e "${RED}Error: Could not parse version${NC}"; exit 1
fi

echo -e "Current version: ${YELLOW}v${CURRENT}${NC}"

MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)

case $TYPE in
    patch) PATCH=$((PATCH + 1)) ;;
    minor) MINOR=$((MINOR + 1)); PATCH=0 ;;
    major) MAJOR=$((MAJOR + 1)); MINOR=0; PATCH=0 ;;
    *) echo "Usage: ./bin/release patch|minor|major \"message\" [--issue N]"; exit 1 ;;
esac

NEW_VERSION="${MAJOR}.${MINOR}.${PATCH}"
DATE=$(date +%Y-%m-%d)
TAG="v${NEW_VERSION}"

echo -e "New version:     ${GREEN}${TAG}${NC}"
echo -e "Message:         ${MSG}"
[[ -n "$ISSUE_ARG" ]] && echo -e "Issues:          #${ISSUE_ARG}"
echo ""

php -r "
\$j = json_decode(file_get_contents('${VERSION_FILE}'), true);
\$j['version'] = '${NEW_VERSION}';
\$j['release_date'] = '${DATE}';
file_put_contents('${VERSION_FILE}', json_encode(\$j, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . \"\n\");
"

echo -e "${BLUE}[1/3] Committing changes...${NC}"

COMMIT_MSG="${TAG}: ${MSG}"
if [[ -n "$ISSUE_ARG" ]]; then
    FIXES=""
    IFS=',' read -ra ISSUES <<< "$ISSUE_ARG"
    for issue in "${ISSUES[@]}"; do
        issue=$(echo "$issue" | tr -d ' ')
        [[ -n "$FIXES" ]] && FIXES="$FIXES, Closes #$issue" || FIXES="Closes #$issue"
    done
    COMMIT_MSG="${TAG}: ${MSG}

${FIXES}"
fi

git add -A
git commit -m "$COMMIT_MSG"

echo -e "${BLUE}[2/3] Creating tag ${TAG}...${NC}"
git tag -a "${TAG}" -m "${MSG}"

echo -e "${BLUE}[3/3] Pushing to origin...${NC}"
git push origin main
git push origin "${TAG}"

if command -v gh &> /dev/null && gh auth status &> /dev/null 2>&1; then
    echo ""
    echo -e "${BLUE}Creating GitHub release...${NC}"

    RELEASE_NOTES="## OpenRiC ${TAG}

**Release Date:** ${DATE}

### Changes
${MSG}"

    if [[ -n "$ISSUE_ARG" ]]; then
        RELEASE_NOTES="${RELEASE_NOTES}

### Related Issues"
        IFS=',' read -ra ISSUES <<< "$ISSUE_ARG"
        for issue in "${ISSUES[@]}"; do
            issue=$(echo "$issue" | tr -d ' ')
            RELEASE_NOTES="${RELEASE_NOTES}
- Closes #${issue}"
        done
    fi

    gh release create "${TAG}" \
        --repo "$REPO" \
        --title "OpenRiC ${TAG}" \
        --notes "${RELEASE_NOTES}" 2>/dev/null || echo "  Release may already exist"

    if [[ -n "$ISSUE_ARG" ]]; then
        echo -e "${BLUE}Updating linked issues...${NC}"
        IFS=',' read -ra ISSUES <<< "$ISSUE_ARG"
        for issue in "${ISSUES[@]}"; do
            issue=$(echo "$issue" | tr -d ' ')
            gh issue close "$issue" --repo "$REPO" \
                --comment "Completed in ${TAG} — ${MSG}" 2>/dev/null || true
        done
    fi
fi

echo ""
echo -e "${GREEN}════════════════════════════════════════════${NC}"
echo -e "${GREEN}  RELEASE COMPLETE: ${TAG}${NC}"
echo -e "${GREEN}════════════════════════════════════════════${NC}"
echo -e "  Version: ${GREEN}${TAG}${NC}  |  Date: ${DATE}"
echo -e "  Message: ${MSG}"
echo ""
