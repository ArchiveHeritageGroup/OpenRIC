{
    "name": "openric/preservation",
    "description": "Preservation planning for OpenRiC — risk assessment, format migration, preservation metadata",
    "type": "library",
    "license": "AGPL-3.0",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\Preservation\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\Preservation\\Providers\\PreservationServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
