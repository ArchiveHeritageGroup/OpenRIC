{
    "name": "openric/term-taxonomy",
    "description": "Term and taxonomy browse and management for OpenRiC",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "openric/core": "@dev"
    },
    "autoload": {
        "psr-4": {
            "OpenRic\\TermTaxonomy\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRic\\TermTaxonomy\\Providers\\TermTaxonomyServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
