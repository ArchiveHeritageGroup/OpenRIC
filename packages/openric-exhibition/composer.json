{
    "name": "openric/exhibition",
    "description": "Exhibition management: virtual and physical exhibitions with items, dates, and locations",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "openric/core": "@dev"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\Exhibition\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\Exhibition\\Providers\\OpenRiCExhibitionServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
