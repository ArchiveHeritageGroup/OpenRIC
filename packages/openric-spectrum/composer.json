{
    "name": "openric/spectrum",
    "description": "Spectrum 5.1 collections management procedures — all 21 procedures, workflow, condition checking, data quality, and export for OpenRiC",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "openric/core": "@dev"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\Spectrum\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\Spectrum\\Providers\\OpenRiCSpectrumServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
