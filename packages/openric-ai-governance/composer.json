{
    "name": "openric/ai-governance",
    "description": "AI Governance Framework for OpenRiC - AI readiness, rights, provenance, and bias management",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/view": "^12.0",
        "illuminate/routing": "^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\AiGovernance\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenRiC\\AiGovernance\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
