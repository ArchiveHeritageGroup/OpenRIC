{
    "name": "openric/export",
    "description": "Export and interoperability services for OpenRiC — JSON-LD, Turtle, RDF/XML, EAD3, EAC-CPF, Dublin Core, IIIF",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "openric/core": "@dev",
        "openric/triplestore": "@dev"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\Export\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\Export\\Providers\\ExportServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
