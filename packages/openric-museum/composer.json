{
    "name": "openric/museum",
    "description": "Museum integration for OpenRiC — collection management, provenance tracking",
    "type": "library",
    "license": "AGPL-3.0",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\Museum\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\Museum\\Providers\\MuseumServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
