{
    "name": "openric/gis",
    "description": "GIS spatial search (bounding box, radius, GeoJSON) for OpenRiC",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "openric/core": "@dev"
    },
    "autoload": {
        "psr-4": {
            "OpenRic\\Gis\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRic\\Gis\\Providers\\GisServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
