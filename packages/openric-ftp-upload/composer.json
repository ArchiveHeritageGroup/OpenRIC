{
    "name": "openric/ftp-upload",
    "description": "FTP/SFTP browser-based upload for CSV import digital objects in OpenRiC",
    "type": "library",
    "require": {
        "openric/core": "@dev"
    },
    "autoload": {
        "psr-4": {
            "OpenRic\\FtpUpload\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRic\\FtpUpload\\Providers\\FtpUploadServiceProvider"
            ]
        }
    }
}
