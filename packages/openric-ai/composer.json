{
    "name": "openric/ai",
    "description": "Ollama embeddings, AI-assisted description for OpenRiC",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "openric/core": "@dev",
        "openric/triplestore": "@dev",
        "openric/search": "@dev"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\AI\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\AI\\Providers\\AIServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}