{
    "name": "openric/authority",
    "description": "Wikidata/VIAF/LCNAF authority linking for OpenRiC",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "openric/core": "@dev",
        "openric/triplestore": "@dev"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\Authority\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\Authority\\Providers\\AuthorityServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}