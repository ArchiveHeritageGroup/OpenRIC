{
    "name": "openric/user-manage",
    "description": "Enhanced admin user management for OpenRiC: browse, create, edit, deactivate, bulk actions",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "openric/core": "@dev"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\UserManage\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\UserManage\\Providers\\OpenRiCUserManageServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
