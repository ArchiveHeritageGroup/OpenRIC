{
    "name": "openric/static-page",
    "description": "Static page management with Markdown rendering, i18n, and protected pages for OpenRiC",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "openric/core": "@dev",
        "league/commonmark": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\StaticPage\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\StaticPage\\Providers\\OpenRiCStaticPageServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
