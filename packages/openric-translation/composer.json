{
    "name": "openric/translation",
    "description": "Machine translation package for OpenRiC — NLLB-200 integration with draft management, 19 languages, 21 translatable fields",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "OpenRiC\\Translation\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\Translation\\Providers\\OpenRiCTranslationServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0"
    }
}
