{
    "name": "openric/audit",
    "description": "Audit trail and change logging for OpenRiC",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "openric/core": "@dev"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\Audit\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\Audit\\Providers\\OpenRiCAuditServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
