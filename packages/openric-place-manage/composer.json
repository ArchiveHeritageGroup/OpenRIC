{
    "name": "openric/place-manage",
    "description": "Place CRUD for OpenRiC",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "openric/core": "@dev",
        "openric/triplestore": "@dev"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\PlaceManage\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\PlaceManage\\Providers\\PlaceManageServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}