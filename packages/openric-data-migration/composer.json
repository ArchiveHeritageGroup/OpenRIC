{
    "name": "openric/data-migration",
    "description": "CSV/data import, column mapping, transformation, and batch migration for OpenRiC",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "openric/core": "@dev"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\DataMigration\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\DataMigration\\Providers\\OpenRiCDataMigrationServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
