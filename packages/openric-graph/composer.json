{
    "name": "openric/graph",
    "description": "D3.js/Cytoscape.js graph visualisation for OpenRiC",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "openric/core": "@dev",
        "openric/triplestore": "@dev"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\Graph\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\Graph\\Providers\\GraphServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
