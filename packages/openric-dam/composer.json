{
    "name": "openric/dam",
    "description": "Digital Asset Management for OpenRiC — asset storage, metadata extraction (IPTC/XMP/PREMIS), and derivative generation",
    "type": "library",
    "license": "AGPL-3.0",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "OpenRiC\\Dam\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenRiC\\Dam\\Providers\\DamServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
